{
  "id": "prpr.bridge",
  "name": "prpr bridge",
  "version": "0.3.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.3"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "prpr.bridge.panel",
      "label": {
        "default": "prpr bridge"
      },
      "minimumSize": { "width": 230, "height": 120 },
      "maximumSize": { "width": 800, "height": 1200 },
      "preferredDockedSize": { "width": 300, "height": 220 },
      "preferredFloatingSize": { "width": 340, "height": 260 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    },
    "clipboard": "readAndWrite",
    "ipc": { "enablePluginCommunication": true },
    "allowCodeGenerationFromStrings": true
  },
  "featureFlags": { "enableAlerts": true }
}
